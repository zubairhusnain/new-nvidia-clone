RewriteEngine On

# Enable contact form and allow POST submissions (see includes/forms-enabled.local.php)
SetEnv CW_ENABLE_FORMS 1

# If the site lives in a subdirectory (not domain docroot), uncomment and set:
# RewriteBase /your-subfolder/

# Do not serve index.php directly — always route through router.php for URL rewriting
DirectoryIndex disabled

# Legacy index.html → clean URL
RewriteRule ^index\.html$ ./ [R=301,L]
RewriteRule ^(.+/)index\.html$ $1 [R=301,L]

# Serve static assets and non-page files (not index.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} !/index\.php$
RewriteRule ^ - [L]

# All page requests → front controller
RewriteRule ^ router.php [L,QSA]
